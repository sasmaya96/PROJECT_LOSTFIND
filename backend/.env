# Copy file ini jadi .env:  cp .env.example .env
# Lalu sesuaikan isinya.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-ganti-ini-dengan-key-yang-panjang-dan-acak
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (SQLite — tidak perlu diubah untuk development) ──────────────────
# Secara default Django pakai db.sqlite3 di root project
# Kalau mau ganti nama file, ubah di config/settings.py → DATABASES
DATABASE_URL=#diisi pake yang kukirim di grup wa
# ── CORS (frontend yang boleh akses API) ─────────────────────────────────────
# DEBUG=True → semua origin diizinkan (aman untuk development)
# Di production ubah CORS_ALLOW_ALL_ORIGINS=False dan isi ini:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://domainmu.com

# ── Media (upload foto) ───────────────────────────────────────────────────────
# Foto disimpan di folder /media/ secara default
# Tidak perlu diubah untuk development lokal

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token berlaku 8 jam, refresh token 7 hari
# Bisa diubah di config/settings.py → SIMPLE_JWT

# ── Channels / WebSocket ─────────────────────────────────────────────────────
# Development: pakai InMemoryChannelLayer (tidak perlu Redis)
# Production: ganti ke RedisChannelLayer, tambahkan:
# REDIS_URL=redis://localhost:6379

CLOUDINARY_URL=#diisi pake yang kukirim di grup wa